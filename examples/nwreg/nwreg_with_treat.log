. do nwreg_with_treat.do 

. clear

. set seed 20250211

. set obs 5000
Number of observations (_N) was 0, now 5,000.

. gen g = mod(_n,2)==0

. gen x = rnormal(1+2*g,2)

. gen treatment = x > runiform()

. gen y = 1 + 2*treatment + 10*treatment*g + 10*sin(x) + rnormal(0,2)

. csadensity x, group(g) treatment(treatment) gen(csa)

Common Support Area (CSA)
----------------------------------------
Variables:    x
Treatment:    treatment
Group vars:   g
Observations: 5000
CSA obs:      473
Threshold:    .2
----------------------------------------

. nwreg y x, target(treatment) group(g) gen(conterfacurals) if(csa==1)
Nadaraya-Watson kernel regression complete
  Regressors: 1
  Observations: 5000
  Kernel: gaussian
  Group variables: 1
  Groups: 2

Nadaraya-Watson regression
----------------------------------------
Dependent:    y
Regressors:   x
Target var:   treatment
              (target=0: training, target=1: test)
Group vars:   g
Groups:       .
Observations: .
Kernel:       gaussian
Bandwidth:    silverman
----------------------------------------

. gen te = y - conterfacurals if treatment==1 & csa==1
(4,725 missing values generated)

. bysort g: su te

-------------------------------------------------------------------------------
-> g = 0

    Variable |        Obs        Mean    Std. dev.       Min        Max
-------------+---------------------------------------------------------
          te |        204    2.109893    2.132691  -3.768895   9.911635

-------------------------------------------------------------------------------
-> g = 1

    Variable |        Obs        Mean    Std. dev.       Min        Max
-------------+---------------------------------------------------------
          te |         71    12.35687    2.483468   7.197979   21.40804


. twoway (scatter y x if treatment==0 & g==0) ///
> (scatter y x if treatment==0 & g==1) ///
> (scatter y x if treatment==1 & g==0) ///
> (scatter y x if treatment==1 & g==1), legend(order(1 "Control, Group 0" 2 "Co
> ntrol, Group 1" 3 "Treatment, Group 0" 4 "Treatment, Group 1")) 

. graph export "scatter_plot1.png", replace
file scatter_plot1.png written in PNG format

. twoway (scatter y x if csa==1 & treatment==1 & g==0) ///
> (scatter y x if csa==1 & treatment==0 & g==0) ///
> (scatter y x if csa==1 & treatment==1 & g==1) ///
> (scatter y x if csa==1 & treatment==0 & g==1) ///
> (scatter conterfacurals x if csa==1 & treatment==1), legend(order(1 "Treatmen
> t, Group 0" 2 "Control, Group 0" 3 "Treatment, Group 1" 4 "Control, Group 1" 
> 5 "Counterfactuals"))

. graph export "scatter_plot2.png", replace
file scatter_plot2.png written in PNG format

. 
end of do-file
