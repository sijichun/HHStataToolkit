. do rf_with_treat.do 

. clear

. set seed 20250211

. set obs 5000
Number of observations (_N) was 0, now 5,000.

. gen g = mod(_n,2)==0

. gen x = rnormal(1+2*g,2)

. gen treatment = x > runiform()

. gen y = 1 + 2*treatment + 10*treatment*g + 10*sin(x) + rnormal(0,2)

. csadensity x, group(g) treatment(treatment) gen(csa)

Common Support Area (CSA)
----------------------------------------
Variables:    x
Treatment:    treatment
Group vars:   g
Observations: 5000
CSA obs:      473
Threshold:    .2
----------------------------------------

. fangorn y x g, type(regress) target(treatment) gen(conterfacurals) if(csa==1)
>  mermaid("rf_with_treat_mermaid.md")

Random forest / decision tree
----------------------------------------
Dep. variable: y
Indep. vars:   x g
Target var:    treatment
               (target=0: training, target=1: test)
Type:          regress
Criterion:     mse
Trees:         1
Max depth:     20
Observations:  473
Prediction var: conterfacurals_pred
Leaf ID var:    conterfacurals
Mermaid file:   rf_with_treat_mermaid.md
----------------------------------------

. gen te = y - conterfacurals_pred if treatment==1 & csa==1
(4,725 missing values generated)

. bysort g: su te

-------------------------------------------------------------------------------
-> g = 0

    Variable |        Obs        Mean    Std. dev.       Min        Max
-------------+---------------------------------------------------------
          te |        204    2.116858    2.230345  -3.910516   9.704371

-------------------------------------------------------------------------------
-> g = 1

    Variable |        Obs        Mean    Std. dev.       Min        Max
-------------+---------------------------------------------------------
          te |         71    12.08592    2.205726   7.581282   19.78497


. twoway (scatter y x if treatment==0 & g==0) ///
> (scatter y x if treatment==0 & g==1) ///
> (scatter y x if treatment==1 & g==0) ///
> (scatter y x if treatment==1 & g==1), legend(order(1 "Control, Group 0" 2 "Co
> ntrol, Group 1" 3 "Treatment, Group 0" 4 "Treatment, Group 1")) 

. graph export "scatter_plot1.png", replace
file scatter_plot1.png written in PNG format

. twoway (scatter y x if csa==1 & treatment==1 & g==0) ///
> (scatter y x if csa==1 & treatment==0 & g==0) ///
> (scatter y x if csa==1 & treatment==1 & g==1) ///
> (scatter y x if csa==1 & treatment==0 & g==1) ///
> (scatter conterfacurals_pred x if csa==1 & treatment==1), legend(order(1 "Tre
> atment, Group 0" 2 "Control, Group 0" 3 "Treatment, Group 1" 4 "Control, Grou
> p 1" 5 "Counterfactuals"))

. graph export "scatter_plot2.png", replace
file scatter_plot2.png written in PNG format

. 
. fangorn y x g, type(regress) ntree(100) target(treatment) gen(conterfacurals_
> rf) if(csa==1)

